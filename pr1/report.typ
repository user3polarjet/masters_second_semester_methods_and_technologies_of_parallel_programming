  let values = nums.pos()
  let n = values.at(0)
  
  let letter = if n <= ukr_alphabet.len() {
    ukr_alphabet.at(n - 1)
  } else {
    str(n)
  }
  
  if values.len() == 1 {
    letter
  } else {
    letter + "." + values.slice(1).map(str).join(".")
  }
})

